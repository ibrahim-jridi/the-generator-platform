  <decision id="test_literal_expression" name="ageCaculation" camunda:historyTimeToLive="180">
    <variable id="InformationItem_1mjiv2g" name="age" typeRef="integer" />
    <literalExpression id="LiteralExpression_1y8fd15" expressionLanguage="feel">
      <text>(years and months duration(date and time(birthDate), now())).years</text>
    </literalExpression>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram>
      <dmndi:DMNShape id="DMNShape_0y2vo1h" dmnElementRef="Decision_04aannm">
