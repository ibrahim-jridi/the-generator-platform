    <!--
        Added the constraints for entity Folder.
    -->
    <changeSet id="20240812143734-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="parent_id"
                                 baseTableName="folder"
                                 constraintName="fk_folder__parent_id"
